{
    "name": "skills_enhance",
    "version": "6.0.0",
    "description": "The web-first, team-ready hub for AI Agent Skills — centralize, discover, lint, synchronize, and federate SKILL.md files across Claude Code, Cursor, Codex, Windsurf, Copilot and 17+ platforms.",
    "license": "MIT",
    "author": "Skill Manager Contributors",
    "keywords": [
        "ai-agent",
        "skills",
        "skill-md",
        "claude-code",
        "cursor",
        "codex",
        "windsurf",
        "copilot",
        "agent-skills",
        "skill-manager",
        "lint",
        "marketplace",
        "mesh",
        "federation",
        "collections",
        "skills-sh",
        "github-import",
        "markdown-editor"
    ],
    "private": true,
    "type": "module",
    "bin": {
        "skill-manager": "./bin/skill-manager.ts"
    },
    "engines": {
        "node": ">=20"
    },
    "scripts": {
        "dev": "vite",
        "dev:all": "run-p server:dev dev",
        "server": "pnpm tsx server/index.ts",
        "server:dev": "nodemon --exec pnpm tsx server/index.ts",
        "build": "tsc -b && vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "test": "vitest",
        "test:run": "vitest run",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "axios": "^1.16.0",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "framer-motion": "^12.38.0",
        "fs-extra": "^11.3.5",
        "gray-matter": "^4.0.3",
        "lucide-react": "^0.471.0",
        "react": "^19.2.5",
        "react-dom": "^19.2.5",
        "unzipper": "^0.12.5",
        "uuid": "^14.0.0"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/fs-extra": "^11.0.4",
        "@types/node": "^24.12.2",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@types/unzipper": "^0.10.11",
        "@types/uuid": "^11.0.0",
        "@vitejs/plugin-react": "^6.0.1",
        "eslint": "^10.2.1",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.5.0",
        "jsdom": "^29.1.1",
        "nodemon": "^3.1.14",
        "npm-run-all": "^4.1.5",
        "ts-node": "^10.9.2",
        "tsx": "^4.21.0",
        "typescript": "~6.0.2",
        "typescript-eslint": "^8.58.2",
        "vite": "^8.0.10",
        "vitest": "^4.1.9"
    },
    "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
